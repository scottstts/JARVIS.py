FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    gcc \
    libc6-dev \
    libsqlite3-dev \
    tini \
  && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir uv

# (Optional but handy) common python dev env vars
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    SQLITE_VEC_VENDOR_VERSION=v0.1.7-alpha.10 \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PATH="/opt/venv/bin:${PATH}"

WORKDIR /repo
COPY pyproject.toml uv.lock README.md ./
COPY src ./src
COPY vendor/sqlite-vec ./vendor/sqlite-vec

RUN mkdir -p /opt/sqlite-vec \
  && gcc -O3 -fPIC -shared \
       "/repo/vendor/sqlite-vec/${SQLITE_VEC_VENDOR_VERSION}/amalgamation/sqlite-vec.c" \
       -o /opt/sqlite-vec/vec0.so \
       -lm \
  && python -c "import os, sqlite3; conn = sqlite3.connect(':memory:'); conn.enable_load_extension(True); conn.load_extension('/opt/sqlite-vec/vec0'); conn.enable_load_extension(False); version = conn.execute('select vec_version()').fetchone()[0]; expected = os.environ['SQLITE_VEC_VENDOR_VERSION']; assert version == expected, (version, expected)" \
  && uv sync --locked --group dev \
  && python -m playwright install --with-deps chromium

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash"]
