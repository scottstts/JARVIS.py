# Dockerfile.dev
FROM python:3.12-slim

# Basic utilities + agent bash-tool command dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash git curl ca-certificates tini \
    bubblewrap \
    file ripgrep zip unzip \
  && rm -rf /var/lib/apt/lists/*

# Install uv (Astral's installer)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
  && ln -s /root/.local/bin/uv /usr/local/bin/uv

# Install ruff (Astral's installer)
RUN curl -LsSf https://astral.sh/ruff/install.sh | sh \
  && ln -s /root/.local/bin/ruff /usr/local/bin/ruff

# (Optional but handy) common python dev env vars
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    JARVIS_TOOL_PYTHON_INTERPRETER_VENV=/opt/jarvis-python-tool-venv \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PATH="/opt/venv/bin:${PATH}"

WORKDIR /tmp/jarvis-deps
COPY pyproject.toml uv.lock ./
COPY src/settings.py ./src/settings.py

# Install locked Python dependencies into an image-level venv so the bind-mounted repo
# does not hide them at runtime, pre-download Chromium for Playwright fallback,
# and prepare the dedicated sandboxed interpreter venv for the future tool.
RUN uv sync --frozen --no-install-project \
  && python -m playwright install --with-deps chromium \
  && python -m venv "${JARVIS_TOOL_PYTHON_INTERPRETER_VENV}" \
  && export JARVIS_PYTHON_TOOL_PACKAGES="$(python -c "import importlib.util; spec = importlib.util.spec_from_file_location('jarvis_settings', 'src/settings.py'); module = importlib.util.module_from_spec(spec); spec.loader.exec_module(module); print(' '.join(module.JARVIS_TOOL_PYTHON_INTERPRETER_ALLOWED_PACKAGES))")" \
  && uv pip install --python "${JARVIS_TOOL_PYTHON_INTERPRETER_VENV}/bin/python" \
       ${JARVIS_PYTHON_TOOL_PACKAGES}

# Work in the mounted workspace by default
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash"]
