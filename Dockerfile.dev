# Dockerfile.dev
FROM python:3.12-slim

# Basic utilities + agent bash-tool command dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash git curl ca-certificates tini \
    file ripgrep \
  && rm -rf /var/lib/apt/lists/*

# Install uv (Astral's installer)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
  && ln -s /root/.local/bin/uv /usr/local/bin/uv

# Install ruff (Astral's installer)
RUN curl -LsSf https://astral.sh/ruff/install.sh | sh \
  && ln -s /root/.local/bin/ruff /usr/local/bin/ruff

# (Optional but handy) common python dev env vars
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Work in the mounted repo by default
WORKDIR /repo

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash"]
