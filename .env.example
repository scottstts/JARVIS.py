# Secrets and machine-specific paths only. Non-secret defaults live in src/settings.py.

# Host-side agent root used by Docker Compose bind mount
AGENT_ROOT=/Users/<username>/.jarvis/workspace/

# For direct host runs only: set the app workspace to the same real host path.
# Inside Docker, leave AGENT_WORKSPACE unset so the app uses /workspace.
# AGENT_WORKSPACE=/Users/<username>/.jarvis/workspace/

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
JARVIS_UI_TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_AI_WORKERS_REST_API_KEY=your_cloudflare_ai_workers_rest_api_key_here
