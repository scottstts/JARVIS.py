# Secrets and machine-specific paths only. Non-secret defaults live in src/settings.py.

# Host-side agent root used by Docker Compose bind mount
AGENT_ROOT=/Users/<username>/.jarvis/workspace/

# In-container workspace path used by the app runtime
AGENT_WORKSPACE=/workspace

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token

# Optional paths
JARVIS_STORAGE_DIR=/workspace/storage
JARVIS_IDENTITIES_DIR=src/identities

# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
