# Agent runtime workspace path (for Docker)
AGENT_WORLD=/Users/<username>/.jarvis/labs/

# -----------------------------------------
# Gateway websocket runtime (optional knobs)
# -----------------------------------------
# JARVIS_GATEWAY_HOST=0.0.0.0
# JARVIS_GATEWAY_PORT=8080
# JARVIS_GATEWAY_WS_PATH=/ws
# JARVIS_GATEWAY_MAX_MESSAGE_CHARS=32000

# -----------------------------------------
# Telegram
# -----------------------------------------
TELEGRAM_TOKEN=your_telegram_bot_token
# Optional Telegram UI knobs
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# JARVIS_UI_TELEGRAM_POLL_TIMEOUT_SECONDS=30
# JARVIS_UI_TELEGRAM_POLL_LIMIT=100
# JARVIS_UI_POLL_ERROR_BACKOFF_SECONDS=2
# JARVIS_UI_STREAM_DRAFT_MIN_INTERVAL_SECONDS=0.4
# JARVIS_UI_STREAM_DRAFT_MIN_CHARS=20
# JARVIS_UI_TELEGRAM_MAX_MESSAGE_CHARS=4096

# Optional explicit gateway websocket URL override for UI.
# If unset, UI derives it from JARVIS_GATEWAY_HOST/PORT/WS_PATH.
# JARVIS_UI_GATEWAY_WS_BASE_URL=ws://127.0.0.1:8080/ws
# JARVIS_UI_GATEWAY_CONNECT_TIMEOUT_SECONDS=15

# -----------------------------------------
# Core context/session policy (global knobs)
# -----------------------------------------
# These values are provider/model agnostic and must match your chosen model.
JARVIS_CONTEXT_WINDOW_TOKENS=400000
JARVIS_COMPACT_THRESHOLD_TOKENS=350000
JARVIS_COMPACT_RESERVE_OUTPUT_TOKENS=16000
JARVIS_COMPACT_RESERVE_OVERHEAD_TOKENS=10000

# Optional paths
# JARVIS_STORAGE_DIR=/Users/<username>/.jarvis/labs/storage
# JARVIS_IDENTITIES_DIR=src/identities

# Core LLM routing/runtime (required)
JARVIS_LLM_DEFAULT_PROVIDER=openai
# JARVIS_LLM_TIMEOUT_SECONDS=60
# JARVIS_LLM_RETRY_ATTEMPTS=2
# JARVIS_LLM_RETRY_BACKOFF_SECONDS=0.5

# Global embedding runtime (required)
JARVIS_EMBEDDING_PROVIDER=openai
JARVIS_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------
# OpenAI Provider Configuration
# ----------------------------
# Required when using provider=openai
OPENAI_API_KEY=your_openai_api_key_here
JARVIS_OPENAI_CHAT_MODEL=gpt-5.2-2025-12-11

# Optional generation defaults
JARVIS_OPENAI_TEMPERATURE=1.0
JARVIS_OPENAI_MAX_OUTPUT_TOKENS=64000
JARVIS_OPENAI_REASONING_EFFORT=none
# JARVIS_OPENAI_REASONING_SUMMARY=auto
# JARVIS_OPENAI_TEXT_VERBOSITY=medium

# -------------------------------
# Anthropic Provider Configuration
# -------------------------------
# Required when using provider=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# JARVIS_ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Optional generation defaults
JARVIS_ANTHROPIC_TEMPERATURE=1.0
JARVIS_ANTHROPIC_MAX_OUTPUT_TOKENS=32000
# Claude 4.6 models: adaptive thinking mode and optional effort
JARVIS_ANTHROPIC_THINKING_MODE=adaptive
JARVIS_ANTHROPIC_EFFORT=medium
# Legacy budget-based thinking (primarily for pre-4.6 models)
# JARVIS_ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# ----------------------------
# Gemini Provider Configuration
# ----------------------------
# Required when using provider=gemini
GOOGLE_API_KEY=your_google_api_key_here
JARVIS_GEMINI_CHAT_MODEL=gemini-3-flash-preview

# Optional generation defaults
JARVIS_GEMINI_TEMPERATURE=1.0
JARVIS_GEMINI_MAX_OUTPUT_TOKENS=64000
JARVIS_GEMINI_THINKING_LEVEL=medium
# Legacy (Gemini 2.5 models): JARVIS_GEMINI_THINKING_BUDGET=1024

# --------------------------------
# OpenRouter Provider Configuration
# --------------------------------
# Required when using provider=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
JARVIS_OPENROUTER_CHAT_MODEL=minimax/minimax-m2.5

# Optional connection settings
OPENROUTER_APP_NAME=Jarvis

# Optional generation defaults
JARVIS_OPENROUTER_TEMPERATURE=0.8
JARVIS_OPENROUTER_MAX_OUTPUT_TOKENS=10000
